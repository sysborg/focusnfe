{
    "name": "sysborg/focusnfe",
    "description": "Integração Laravel com a FocusNFe para NFe, NFCe, CTe, MDFe e NFSe",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nfe",
        "nfce",
        "cte",
        "mdfe",
        "fiscal",
        "sefaz",
        "focus",
        "laravel"
    ],
    "autoload": {
        "psr-4": {
            "Sysborg\\FocusNfe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sysborg\\FocusNfe\\tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Sysborg",
            "email": "contato@sysborg.com.br"
        },
        {
            "name": "Anderson Arruda",
            "email": "andmarruda@gmail.com"
        },
        {
            "name": "Eder Venancio"
        }
    ],
    "require": {
        "php": ">=8.0",
        "laravel/framework": ">=9.0",
        "laravel/sanctum": ">=2.11"
    },
    "require-dev": {
        "laravel/pint": "^1.21",
        "nunomaduro/larastan": "^2.9",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^10.5",
        "pestphp/pest": "^2.36"
    },
    "scripts": {
        "test": "phpunit",
        "test:pest": "pest",
        "analyse": "phpstan analyse --memory-limit=1G",
        "lint": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sysborg\\FocusNfe\\app\\Providers\\SBFocusNFeProvider"
            ],
            "aliases": {
                "FocusNfe": "Sysborg\\FocusNfe\\app\\Facades\\FocusNfe"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
